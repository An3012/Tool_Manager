                        <span id="modalSellTiming" class="small px-2 py-0-5 rounded" style="background: rgba(239, 68, 68, 0.12); color: var(--accent-red); font-size: 0.7rem; font-weight: 600;">--</span>
                    </div>
                    <div class="small text-secondary mb-2" style="font-size: 0.78rem;">
                        Mốc chốt lời: <span id="modalSellTp" class="text-success fw-bold">--</span> | Ngưỡng cắt lỗ: <span id="modalSellSl" class="text-danger fw-bold">--</span>
                    </div>
