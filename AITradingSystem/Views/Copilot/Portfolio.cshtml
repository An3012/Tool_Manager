    <input type="hidden" name="currentPrice" id="sellPrice" />
</form>

<form id="buyMoreForm" asp-action="AddMorePosition" method="post" style="display:none;">
    <input type="hidden" name="id" id="buyMoreId" />
</form>

<form id="partialSellForm" asp-action="SellPartialPosition" method="post" style="display:none;">
