@using AITradingSystem.Models
@using AITradingSystem.Controllers
@{
    ViewData["Title"] = "Danh mục đầu tư - DNSE AI";
    var positions = ViewBag.Positions as List<TradePosition> ?? new List<TradePosition>();
    var openPositions = positions.Where(p => p.Status == "OPEN").ToList();
    var stocks = ViewBag.Stocks as List<StockViewModel> ?? new List<StockViewModel>();
    var pref = (ViewBag.Preference as UserPreference) ?? new UserPreference();
    var totalPnL = (decimal?)ViewBag.TotalPnL ?? 0;
    var totalTargetAmount = (decimal?)ViewBag.TotalTargetAmount ?? 0;
    var analysisMap = ViewBag.AnalysisMap as Dictionary<int, PositionAnalysis> ?? new Dictionary<int, PositionAnalysis>();
    var allocatedBudget = (decimal?)ViewBag.AllocatedBudget ?? 0;
    var remainingOtherBudget = (decimal?)ViewBag.RemainingOtherBudget ?? 0;
    var totalRealizedPnL = (decimal?)ViewBag.TotalRealizedPnL ?? 0;
    var cumulativePnL = (decimal?)ViewBag.CumulativePnL ?? 0;
    var globalPlan = ViewBag.GlobalPlan as AITradingSystem.Services.GlobalPortfolioPlanResult;

    DateTime startDate = pref.PlanStartDate ?? DateTime.Today;
    int totalDays = 30;
    if (!string.IsNullOrEmpty(pref.InvestmentHorizon))
    {
        var match = System.Text.RegularExpressions.Regex.Match(pref.InvestmentHorizon, @"\d+");
        if (match.Success) int.TryParse(match.Value, out totalDays);
    }
    DateTime endDate = startDate.AddDays(totalDays);
    int remainingDays = (endDate.Date - DateTime.Now.Date).Days;
    if (remainingDays < 0) remainingDays = 0;
    decimal targetAmountToUse = totalTargetAmount > 0 ? totalTargetAmount : pref.TargetAmount;
    decimal remainingAmountTotal = Math.Max(0m, targetAmountToUse - cumulativePnL);
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --bg-dark: #090a0f;
        --card-bg: rgba(20, 22, 37, 0.6);
        --border-color: rgba(255, 255, 255, 0.08);
        --text-primary: #f3f4f6;
        --text-secondary: #9ca3af;
        --accent-green: #10b981;
        --accent-red: #ef4444;
        --accent-purple: #8b5cf6;
        --accent-blue: #3b82f6;
        --accent-amber: #f59e0b;
        --accent-cyan: #06b6d4;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-primary);
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .glass-card {
        background: var(--card-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    }

    .gradient-text {
        background: linear-gradient(135deg, #a78bfa 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .pnl-positive { color: var(--accent-green); }
    .pnl-negative { color: var(--accent-red); }

    .risk-input {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-color);
        color: white;
        border-radius: 8px;
        padding: 6px 10px;
        width: 110px;
        font-size: 0.85rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .risk-input:focus {
        outline: none;
        border-color: var(--accent-purple);
        box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.15);
    }

    .risk-input.target-input {
        border-color: rgba(245, 158, 11, 0.3);
        width: 130px;
    }

    .risk-input.target-input:focus {
        border-color: var(--accent-amber);
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.15);
    }

    /* Summary Cards */
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }

    .summary-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 14px;
        padding: 20px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .summary-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
    }

    .summary-card.pnl-card::before { background: linear-gradient(90deg, #10b981, #06b6d4); }
    .summary-card.target-card::before { background: linear-gradient(90deg, #f59e0b, #ef4444); }
    .summary-card.progress-card::before { background: linear-gradient(90deg, #8b5cf6, #3b82f6); }
    .summary-card.count-card::before { background: linear-gradient(90deg, #06b6d4, #8b5cf6); }

    .summary-card .card-label {
        font-size: 0.78rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
    }

    .summary-card .card-value {
        font-size: 1.6rem;
        font-weight: 700;
    }

    /* Progress Bar */
    .progress-container {
        width: 100%;
        height: 8px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 4px;
        overflow: hidden;
        margin: 6px 0;
    }

    .progress-bar-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.8s ease-out;
        min-width: 2px;
    }

    .progress-bar-fill.positive {
        background: linear-gradient(90deg, #10b981, #06b6d4);
    }

    .progress-bar-fill.negative {
        background: linear-gradient(90deg, #ef4444, #f97316);
    }

    .progress-bar-fill.warning {
        background: linear-gradient(90deg, #f59e0b, #eab308);
    }

    .progress-bar-fill.complete {
        background: linear-gradient(90deg, #10b981, #34d399);
        animation: pulseGlow 1.5s ease-in-out infinite;
    }

    @@keyframes pulseGlow {
        0%, 100% { box-shadow: 0 0 4px rgba(16, 185, 129, 0.4); }
        50% { box-shadow: 0 0 12px rgba(16, 185, 129, 0.8); }
    }

    /* AI Signal Badge */
    .ai-signal {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        white-space: nowrap;
    }

    .ai-signal.sell {
        color: #fca5a5;
        background: rgba(239, 68, 68, 0.15);
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .ai-signal.watch {
        color: #fcd34d;
        background: rgba(245, 158, 11, 0.15);
        border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .ai-signal.hold {
        color: #93c5fd;
        background: rgba(59, 130, 246, 0.15);
        border: 1px solid rgba(59, 130, 246, 0.3);
    }

    .ai-signal.caution {
        color: #fdba74;
        background: rgba(249, 115, 22, 0.15);
        border: 1px solid rgba(249, 115, 22, 0.3);
    }

    .ai-signal.none {
        color: #6b7280;
        background: rgba(107, 114, 128, 0.1);
        border: 1px solid rgba(107, 114, 128, 0.2);
    }

    /* AI Analysis Tooltip / Row */
    .ai-reason-text {
        font-size: 0.78rem;
        color: var(--text-secondary);
        margin-top: 4px;
        line-height: 1.4;
    }

    /* Position Row */
    .position-row {
        border-bottom: 1px solid var(--border-color);
        transition: background 0.2s;
    }

    .position-row:hover {
        background: rgba(139, 92, 246, 0.04);
    }

    .position-row:last-child {
        border-bottom: none;
    }

    /* Target Section */
    .target-section {
        background: rgba(245, 158, 11, 0.04);
        border: 1px solid rgba(245, 158, 11, 0.12);
        border-radius: 10px;
        padding: 12px 16px;
        margin-top: 8px;
    }

    .target-label {
        font-size: 0.72rem;
        color: var(--accent-amber);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 4px;
    }

    /* Source Badge */
    .source-badge {
        font-size: 0.73rem;
        padding: 4px 8px;
        border-radius: 4px;
        display: inline-block;
    }

    .source-badge.ai {
        color: #d8b4fe;
        border: 1px solid rgba(167, 139, 250, 0.4);
        background: rgba(139, 92, 246, 0.15);
    }

    .source-badge.real {
        color: #86efac;
        border: 1px solid rgba(34, 197, 94, 0.4);
        background: rgba(34, 197, 94, 0.15);
    }

    /* Action Buttons */
    .btn-save-target {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(59, 130, 246, 0.2));
        border: 1px solid rgba(139, 92, 246, 0.3);
        color: #c4b5fd;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 0.82rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-save-target:hover {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.35), rgba(59, 130, 246, 0.35));
        border-color: rgba(139, 92, 246, 0.5);
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.2);
    }

    .btn-sell {
        background: rgba(239, 68, 68, 0.15);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #fca5a5;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 0.82rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-sell:hover {
        background: rgba(239, 68, 68, 0.3);
        border-color: rgba(239, 68, 68, 0.5);
        color: white;
        transform: translateY(-1px);
    }

    /* Responsive table wrapper */
    .position-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 12px;
    }

    .position-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border-color);
    }

    .position-body {
        padding: 16px 20px;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 12px;
    }

    .stat-item .stat-label {
        font-size: 0.72rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .stat-item .stat-value {
        font-size: 0.95rem;
        font-weight: 600;
        margin-top: 2px;
    }

    /* Detailed Transaction History Timeline */
    .transaction-section {
        background: rgba(255, 255, 255, 0.015);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 16px;
    }

    .timeline-container {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .timeline-item {
        position: relative;
        padding-bottom: 4px;
    }

    .timeline-item:last-child {
        margin-bottom: 0 !important;
    }
</style>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="fw-bold mb-1"><span class="gradient-text">Danh mục đầu tư</span></h1>
            <p class="text-secondary m-0">
                Tổng vốn đầu tư: <strong class="text-white">@pref.AmountPerTrade.ToString("N0") đ</strong> | 
                Đã phân bổ: <strong class="text-info">@allocatedBudget.ToString("N0") đ</strong> | 
                Vốn còn lại mã khác: <strong class="text-warning">@remainingOtherBudget.ToString("N0") đ</strong> |
                Ngày hết hạn: <strong class="text-white">@endDate.ToString("dd/MM/yyyy")</strong> |
                Số ngày còn lại: <strong class="text-danger">@remainingDays ngày</strong> |
                Còn thiếu mục tiêu: <strong class="text-warning">@remainingAmountTotal.ToString("N0") đ</strong>
            </p>
        </div>
        <div>
            @if (ViewBag.PlanStatus == "Pending")
            {
                <button class="btn btn-outline-purple text-purple fw-bold d-flex align-items-center gap-2" disabled style="border-color: var(--accent-purple); color: #c084fc; background: rgba(139, 92, 246, 0.08); border-radius: 12px; padding: 10px 20px; font-size: 0.9rem;">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    AI đang phân tích...
                </button>
            }
            else
            {
                <form asp-action="RunPlanAnalysis" method="post" id="runPlanForm" class="m-0">
                    <button type="submit" onclick="showGlobalLoading()" class="btn text-white fw-bold d-flex align-items-center gap-2" style="background: linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%); border-radius: 12px; padding: 10px 20px; border: none; box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3); cursor: pointer; transition: all 0.2s; font-size: 0.9rem;">
                        <span>🧠</span> AI Phân tích và dự đoán kế hoạch
                    </button>
                </form>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-opacity-10 border-success text-success alert-dismissible fade show mb-4" role="alert" style="background: rgba(16,185,129,0.08); border-color: rgba(16,185,129,0.3) !important;">
            ✅ @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Summary Dashboard -->
    <div class="summary-grid mb-4">
        <div class="summary-card pnl-card">
            <div class="card-label">Tổng lãi/lỗ đã hiện thực</div>
            <div class="card-value @(totalRealizedPnL >= 0 ? "pnl-positive" : "pnl-negative")">
                @(totalRealizedPnL >= 0 ? "+" : "")@totalRealizedPnL.ToString("N0") đ
            </div>
        </div>
        <div class="summary-card pnl-card" style="border-top: 3px solid var(--accent-blue);">
            <div class="card-label">Tổng lãi/lỗ tạm tính</div>
            <div class="card-value @(totalPnL >= 0 ? "pnl-positive" : "pnl-negative")">
                @(totalPnL >= 0 ? "+" : "")@totalPnL.ToString("N0") đ
            </div>
        </div>
        <div class="summary-card pnl-card" style="border-top: 3px solid var(--accent-purple);">
            <div class="card-label">Tổng lợi nhuận tích lũy</div>
            <div class="card-value @(cumulativePnL >= 0 ? "pnl-positive" : "pnl-negative")">
                @(cumulativePnL >= 0 ? "+" : "")@cumulativePnL.ToString("N0") đ
            </div>
        </div>
        <div class="summary-card target-card">
            <div class="card-label">Mục tiêu lợi nhuận tổng thể</div>
            <div class="card-value" style="color: var(--accent-amber);">
                @targetAmountToUse.ToString("N0") đ
            </div>
        </div>
        <div class="summary-card progress-card">
            <div class="card-label">Tiến độ mục tiêu tổng thể</div>
            @{
                var overallProgress = targetAmountToUse > 0 ? Math.Min(100, Math.Max(-100, cumulativePnL / targetAmountToUse * 100)) : 0;
            }
            <div class="card-value" style="color: var(--accent-purple);">
                @overallProgress.ToString("N1")%
            </div>
            <div class="progress-container mt-2">
                <div class="progress-bar-fill @(overallProgress >= 100 ? "complete" : overallProgress >= 0 ? "positive" : "negative")"
                     style="width: @(Math.Max(0, overallProgress))%"></div>
            </div>
        </div>
    </div>

    <!-- AI Hoạch Định & Tối Ưu Danh Mục -->
    @if (ViewBag.PlanStatus == "Pending")
    {
        <div class="glass-card mb-4 text-center py-5" style="border: 1px dashed rgba(139, 92, 246, 0.4); background: rgba(139, 92, 246, 0.02);">
            <div class="spinner-border text-primary mb-3" style="color: var(--accent-purple) !important;" role="status"></div>
            <h5 class="fw-bold text-white">AI đang phân tích và lập kế hoạch tối ưu danh mục...</h5>
            <p class="text-secondary small mb-0">Hệ thống đang chạy tác vụ tối ưu hóa xác suất đạt mục tiêu cuối kỳ (khoảng 15-30 giây). Trang sẽ tự động tải lại khi hoàn thành.</p>
        </div>
    }
    else if (globalPlan != null)
    {
        <div class="glass-card mb-4" style="background: rgba(139, 92, 246, 0.03); border: 1px solid rgba(139, 92, 246, 0.15); padding: 24px;">
            <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <span style="font-size: 1.5rem;">🧠</span>
                    <div>
                        <h4 class="m-0 text-white fw-bold" style="font-size: 1.1rem;">AI Hoạch Định & Tối Ưu Danh Mục Tổng Thể</h4>
                        <span class="text-secondary" style="font-size: 0.78rem;">
                            Định hướng giao dịch từ ngày <strong class="text-white">@globalPlan.StartDate.ToString("dd/MM/yyyy")</strong> đến ngày <strong class="text-white">@globalPlan.EndDate.ToString("dd/MM/yyyy")</strong> (còn <strong class="text-danger">@globalPlan.RemainingDays ngày</strong>)
                        </span>
                    </div>
                </div>
                <div class="text-end">
                    <div style="font-size: 0.75rem; color: var(--accent-purple); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Xác suất đạt mục tiêu cuối kỳ</div>
                    <div class="d-flex align-items-center gap-2 mt-1 justify-content-end">
                        <span class="fw-bold" style="font-size: 1.3rem; color: @(globalPlan.SuccessProbability >= 80 ? "var(--accent-green)" : globalPlan.SuccessProbability >= 50 ? "var(--accent-amber)" : "var(--accent-red)");">
                            @globalPlan.SuccessProbability.ToString("N1")%
                        </span>
                        <div class="progress-container" style="width: 80px; height: 8px; margin: 0;">
                            <div class="progress-bar-fill @(globalPlan.SuccessProbability >= 80 ? "complete" : globalPlan.SuccessProbability >= 50 ? "positive" : "negative")" style="width: @globalPlan.SuccessProbability%"></div>
                        </div>
                    </div>
                </div>
            </div>
 
            <div class="row g-3">
                <!-- Plan Summary -->
                <div class="col-12">
                    <div class="p-3 rounded" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05);">
                        <div class="fw-bold text-white mb-1" style="font-size: 0.85rem; color: var(--accent-cyan) !important;">📝 Tóm tắt kế hoạch hành động:</div>
                        <p class="m-0 text-secondary" style="font-size: 0.85rem; line-height: 1.5;">@globalPlan.PlanSummary</p>
                    </div>
                </div>
 
                <!-- Actions Table -->
                <div class="col-md-7">
                    <div class="p-3 rounded h-100" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05);">
                        <div class="fw-bold text-white mb-2" style="font-size: 0.85rem; color: var(--accent-purple) !important;">🔄 Đề xuất điều chuyển vốn & Giao dịch:</div>
                        @if (globalPlan.Actions != null && globalPlan.Actions.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-dark table-hover m-0" style="font-size: 0.8rem; border-color: rgba(255,255,255,0.03);">
                                    <thead>
                                        <tr class="text-secondary" style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                            <th>Mã CP</th>
                                            <th>Hành động</th>
                                            <th>Chi tiết điều chuyển vốn</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var act in globalPlan.Actions)
                                        {
                                            var actClass = act.Action switch
                                            {
                                                "MUA" => "pnl-positive",
                                                "MUA THÊM" => "pnl-positive",
                                                "BÁN" => "pnl-negative",
                                                "CHUYỂN VỐN" => "text-info",
                                                _ => "text-secondary"
                                            };
                                            <tr>
                                                <td class="fw-bold text-white">@act.Ticker</td>
                                                <td><span class="badge" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); font-size: 0.72rem; color: inherit; padding: 3px 6px; display: inline-block;">@act.Action</span></td>
                                                <td class="text-secondary">@act.Description</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <span class="text-secondary small">Chưa có đề xuất giao dịch nào.</span>
                        }
                    </div>
                </div>
 
                <!-- Contributions -->
                <div class="col-md-5">
                    <div class="p-3 rounded h-100" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05);">
                        <div class="fw-bold text-white mb-2" style="font-size: 0.85rem; color: var(--accent-amber) !important;">💰 Dự báo đóng góp lợi nhuận mục tiêu:</div>
                        @if (globalPlan.ExpectedContributions != null && globalPlan.ExpectedContributions.Any())
                        {
                            <div class="d-flex flex-column gap-2">
                                @foreach (var contrib in globalPlan.ExpectedContributions)
                                {
                                    <div class="p-2 rounded" style="background: rgba(255, 255, 255, 0.015); border: 1px solid rgba(255, 255, 255, 0.03);">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="fw-bold text-white" style="font-size: 0.82rem;">@contrib.Ticker</span>
                                            <span class="pnl-positive fw-bold" style="font-size: 0.82rem;">+@contrib.ExpectedProfit.ToString("N0") đ</span>
                                        </div>
                                        <div class="text-secondary mt-1" style="font-size: 0.74rem;">@contrib.Description</div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="text-secondary small">Chưa có phân tích đóng góp.</span>
                        }
                    </div>
                </div>
 
                <!-- Rationale -->
                <div class="col-12">
                    <div class="p-3 rounded" style="background: rgba(139, 92, 246, 0.015); border: 1px solid rgba(139, 92, 246, 0.05);">
                        <div class="fw-bold text-white mb-1" style="font-size: 0.85rem; color: var(--accent-green) !important;">📊 Phân tích cơ sở & Quản trị rủi ro lý thuyết:</div>
                        <p class="m-0 text-secondary" style="font-size: 0.82rem; line-height: 1.5; font-style: italic;">@globalPlan.Rationale</p>
                    </div>
                </div>

                <!-- Daily Action Calendar -->
                <div class="col-12 mt-3">
                    <div class="p-3 rounded" style="background: rgba(139, 92, 246, 0.02); border: 1px solid rgba(139, 92, 246, 0.1);">
                        <div class="fw-bold text-white mb-3" style="font-size: 0.85rem; color: var(--accent-cyan) !important;">📅 Lịch trình giao dịch tối ưu từng ngày (Daily Action Calendar):</div>
                        @if (globalPlan.DailyCalendar != null && globalPlan.DailyCalendar.Any())
                        {
                            foreach (var dateGroup in globalPlan.DailyCalendar.GroupBy(x => x.Date))
                            {
                                <div class="mb-4">
                                    <h6 class="text-white fw-bold mb-2 pb-1" style="border-bottom: 1px solid rgba(139, 92, 246, 0.2); display: inline-block;">
                                        <i class="bi bi-calendar-event me-2" style="color: var(--accent-purple);"></i> Ngày @dateGroup.Key <span class="text-secondary fw-normal ms-1">(@dateGroup.First().DayOfWeek)</span>
                                    </h6>
                                    <div class="table-responsive">
                                        <table class="table table-sm table-dark table-hover m-0" style="font-size: 0.8rem; border-color: rgba(255,255,255,0.03);">
                                            <thead>
                                                <tr class="text-secondary" style="border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.75rem;">
                                                    <th style="width: 45%;">Hành động đề xuất (Step-by-step)</th>
                                                    <th style="width: 15%;">Mục tiêu giao dịch</th>
                                                    <th style="width: 15%;">PnL tích lũy</th>
                                                    <th style="width: 25%;">Hành động thực tế</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in dateGroup)
                                                {
                                                    var badgeClass = item.ActionType switch
                                                    {
                                                        "MUA" => "bg-success",
                                                        "MUA THÊM" => "bg-success",
                                                        "BÁN" => "bg-danger",
                                                        "CƠ CẤU" => "bg-warning text-dark",
                                                        "TẤT TOÁN" => "bg-primary",
                                                        "SÀN ĐÓNG CỬA" => "bg-secondary",
                                                        _ => "bg-secondary"
                                                    };
                                                    <tr>
                                                        <td>
                                                            @if (item.ActionType != "GIỮ" && item.ActionType != "SÀN ĐÓNG CỬA")
                                                            {
                                                                <span class="badge @badgeClass me-2" style="font-size: 0.65rem; padding: 3px 6px;">@item.ActionType</span>
                                                            }
                                                            else if (item.ActionType == "GIỮ")
                                                            {
                                                                <span class="badge bg-secondary me-2" style="font-size: 0.65rem; padding: 3px 6px;">@item.ActionType</span>
                                                            }
                                                            @Html.Raw(System.Text.RegularExpressions.Regex.Replace(item.Description, @"\*\*(.*?)\*\*", "<strong>$1</strong>"))
                                                        </td>
                                                        <td class="@(item.Target.Contains("+") ? "pnl-positive fw-bold" : "text-secondary")">@item.Target</td>
                                                        <td class="text-info fw-bold">@item.CumulativePnL</td>
                                                        <td class="text-secondary" style="font-size: 0.8rem; line-height: 1.4;">@Html.Raw(item.ActualAction)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <span class="text-secondary small">Chưa có lịch trình giao dịch.</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="glass-card mb-4 text-center py-5" style="border: 1px dashed rgba(255, 255, 255, 0.1); background: rgba(255,255,255,0.01);">
            <div style="font-size: 2.5rem; margin-bottom: 12px;">🧠</div>
            <h5 class="fw-bold text-white">Chưa có kế hoạch đầu tư AI tổng thể</h5>
            <p class="text-secondary small mb-3">Vui lòng bấm nút "AI Phân tích và dự đoán kế hoạch" ở góc trên bên phải để bắt đầu thiết lập kế hoạch tối ưu hóa danh mục.</p>
            <form asp-action="RunPlanAnalysis" method="post" class="d-inline-block">
                <button type="submit" onclick="showGlobalLoading()" class="btn text-white fw-bold d-flex align-items-center gap-2" style="background: linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%); border-radius: 8px; padding: 8px 16px; border: none; cursor: pointer;">
                    🧠 Khởi chạy phân tích AI
                </button>
            </form>
        </div>
    }

    <!-- Position List -->
    @if (!openPositions.Any())
    {
        <div class="glass-card text-center py-5">
            <div style="font-size: 3rem; margin-bottom: 16px;">📊</div>
            <p class="text-secondary mb-2">Bạn chưa có cổ phiếu nào trong danh mục.</p>
            <a asp-action="Index" class="text-info" style="text-decoration: none;">
                ← Quay lại Dashboard để tìm tín hiệu mua
            </a>
        </div>
    }
    else
    {
        foreach (var pos in openPositions)
        {
            var currentPrice = stocks.FirstOrDefault(s => s.Symbol == pos.Symbol)?.CurrentPrice ?? pos.EntryPrice;
            var pnl = (currentPrice - pos.EntryPrice) * pos.Quantity;
            var pnlPercent = pos.EntryPrice > 0 ? (currentPrice - pos.EntryPrice) / pos.EntryPrice * 100 : 0;
            var analysis = analysisMap.ContainsKey(pos.Id) ? analysisMap[pos.Id] : null;
            var hasTarget = pos.TargetProfitAmount.HasValue && pos.TargetProfitAmount.Value > 0;

            <div class="position-card">
                <!-- Position Header -->
                <div class="position-header">
                    <div class="d-flex align-items-center gap-3">
                        <div>
                            <span class="fw-bold text-white" style="font-size: 1.15rem;">@pos.Symbol</span>
                            <span class="source-badge real ms-2">💼 Lệnh thật</span>
                            <span class="badge ms-2" style="font-size: 0.8rem; background: rgba(139, 92, 246, 0.15); border: 1px solid rgba(139, 92, 246, 0.3); color: #d8b4fe;">
                                📦 Số CP còn lại: @pos.Quantity.ToString("N0") CP
                            </span>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="@(pnl >= 0 ? "pnl-positive" : "pnl-negative")" style="font-size: 1.25rem; font-weight: 700;">
                            @(pnl >= 0 ? "+" : "")@pnl.ToString("N0") đ
                        </div>
                        <div class="small @(pnlPercent >= 0 ? "pnl-positive" : "pnl-negative")" style="font-size: 0.82rem;">
                            (@pnlPercent.ToString("N2")%)
                        </div>
                    </div>
                </div>

                <div class="position-body">
                    <!-- Stats Grid -->
                    <div class="stat-grid mb-3">
                        <div class="stat-item">
                            <div class="stat-label">Số CP còn lại</div>
                            <div class="stat-value text-white">@(pos.Quantity == 0 ? "0 CP (Đã chốt)" : $"{pos.Quantity.ToString("N0")} CP")</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-label">Giá vốn</div>
                            <div class="stat-value">@pos.EntryPrice.ToString("N0") đ</div>
                        </div>
                        @if (pos.InvestedAmount.HasValue && pos.InvestedAmount.Value > 0)
                        {
                            <div class="stat-item">
                                <div class="stat-label">💰 Vốn đầu tư</div>
                                <div class="stat-value" style="color: var(--accent-amber);">@pos.InvestedAmount.Value.ToString("N0") đ</div>
                            </div>
                        }
                        <div class="stat-item">
                            <div class="stat-label">Giá hiện tại</div>
                            <div class="stat-value @(currentPrice >= pos.EntryPrice ? "pnl-positive" : "pnl-negative")">@currentPrice.ToString("N0") đ</div>
                        </div>
                        @if (pos.TakeProfitPrice.HasValue && pos.TakeProfitPrice.Value > 0)
                        {
                            <div class="stat-item">
                                <div class="stat-label">Giá chốt lời</div>
                                <div class="stat-value" style="color: var(--accent-green);">@pos.TakeProfitPrice.Value.ToString("N0") đ</div>
                            </div>
                        }
                        @if (pos.StopLossPrice.HasValue && pos.StopLossPrice.Value > 0)
                        {
                            <div class="stat-item">
                                <div class="stat-label">Giá cắt lỗ</div>
                                <div class="stat-value" style="color: var(--accent-red);">@pos.StopLossPrice.Value.ToString("N0") đ</div>
                            </div>
                        }
                        @if (analysis != null)
                        {
                            @if (pos.ExpectedHoldDays.HasValue && pos.ExpectedHoldDays.Value > 0)
                            {
                                <div class="stat-item">
                                    <div class="stat-label">⏳ Thời gian giữ</div>
                                    <div class="stat-value" style="color: var(--accent-purple);">
                                        @analysis.DaysHeld / @pos.ExpectedHoldDays.Value ngày
                                    </div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-label">⏳ Ngày còn lại</div>
                                    @if (analysis.RemainingDays.HasValue)
                                    {
                                        if (analysis.RemainingDays.Value <= 0)
                                        {
                                            <div class="stat-value" style="color: var(--accent-red); font-weight: bold;">
                                                Quá hạn @Math.Abs(analysis.RemainingDays.Value) ngày
                                            </div>
                                        }
                                        else if (analysis.RemainingDays.Value <= 2)
                                        {
                                            <div class="stat-value" style="color: var(--accent-amber); font-weight: bold;">
                                                Còn @analysis.RemainingDays.Value ngày
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="stat-value" style="color: var(--accent-green);">
                                                Còn @analysis.RemainingDays.Value ngày
                                            </div>
                                        }
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="stat-item">
                                    <div class="stat-label">⏳ Đã giữ</div>
                                    <div class="stat-value">@analysis.DaysHeld ngày</div>
                                </div>
                            }
                        }
                    </div>

                    <!-- Active Buy Lots (FIFO Breakdown) -->
                    @if (analysis != null && analysis.ActiveLots != null && analysis.ActiveLots.Any())
                    {
                        <div class="mb-3 p-3 rounded" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05);">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span style="font-size: 1rem;">📊</span>
                                <span style="font-size: 0.75rem; color: var(--accent-cyan); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Chi tiết các lô mua (FIFO)</span>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm table-dark table-hover m-0" style="font-size: 0.82rem; border-color: rgba(255,255,255,0.05);">
                                    <thead>
                                        <tr class="text-secondary" style="font-size: 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                            <th>Ngày mua</th>
                                            <th class="text-end">Số lượng còn</th>
                                            <th class="text-end">Giá mua (Vốn)</th>
                                            <th class="text-end">Giá hiện tại</th>
                                            <th class="text-end">Lãi/Lỗ tạm tính</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var lot in analysis.ActiveLots)
                                        {
                                            <tr>
                                                <td class="text-secondary">@lot.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td class="text-end fw-semibold">@lot.RemainingQuantity.ToString("N0") <span class="text-secondary" style="font-size: 0.72rem;">/ @lot.OriginalQuantity.ToString("N0") CP</span></td>
                                                <td class="text-end">@lot.EntryPrice.ToString("N0") đ</td>
                                                <td class="text-end">@lot.CurrentPrice.ToString("N0") đ</td>
                                                <td class="text-end fw-bold @(lot.PnL >= 0 ? "pnl-positive" : "pnl-negative")">
                                                    @(lot.PnL >= 0 ? "+" : "")@lot.PnL.ToString("N0") đ
                                                    <span style="font-size: 0.72rem; font-weight: normal; margin-left: 2px;">
                                                        (@(lot.PnLPercent >= 0 ? "+" : "")@lot.PnLPercent.ToString("N2")%)
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    <!-- Target Progress Section -->
                    @if (hasTarget && analysis != null)
                    {
                        <div class="target-section mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="target-label">🎯 Mục tiêu lợi nhuận sau bán</div>
                                <div class="d-flex align-items-center gap-2">
                                    <span style="font-size: 0.85rem; font-weight: 600; color: var(--accent-amber);">
                                        Mục tiêu: @pos.TargetProfitAmount.Value.ToString("N0") đ
                                    </span>
                                </div>
                            </div>
                            <div class="progress-container" style="height: 10px; margin-bottom: 8px;">
                                @{
                                    var progressPct = analysis.ProgressPercent;
                                    var barClass = progressPct >= 100 ? "complete" : progressPct >= 80 ? "warning" : progressPct >= 0 ? "positive" : "negative";
                                    var barWidth = Math.Max(0, Math.Min(100, progressPct));
                                }
                                <div class="progress-bar-fill @barClass" style="width: @barWidth%"></div>
                            </div>
                            
                            <div class="d-flex flex-column gap-1 text-secondary" style="font-size: 0.78rem; border-top: 1px dashed rgba(255,255,255,0.05); padding-top: 6px;">
                                <div class="d-flex justify-content-between">
                                    <span>Lãi tạm tính (Floating PnL):</span>
                                    <span class="@(pos.PnL >= 0 ? "pnl-positive" : "pnl-negative") fw-semibold">
                                        @(pos.PnL >= 0 ? "+" : "")@pos.PnL.ToString("N0") đ
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span>Lãi đã hiện thực (Realized PnL):</span>
                                    <span class="@(analysis.SymbolRealizedPnL >= 0 ? "pnl-positive" : "pnl-negative") fw-semibold">
                                        @(analysis.SymbolRealizedPnL >= 0 ? "+" : "")@analysis.SymbolRealizedPnL.ToString("N0") đ
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between fw-bold text-white border-top border-secondary border-opacity-20 pt-1" style="font-size: 0.8rem;">
                                    <span>Lũy kế của mã (Cumulative):</span>
                                    <span class="@(analysis.SymbolCumulativePnL >= 0 ? "pnl-positive" : "pnl-negative")">
                                        @(analysis.SymbolCumulativePnL >= 0 ? "+" : "")@analysis.SymbolCumulativePnL.ToString("N0") đ (@progressPct.ToString("N1")%)
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between mt-1 small">
                                    <span>Còn thiếu:</span>
                                    <span class="text-warning font-monospace">@analysis.RemainingAmount.ToString("N0") đ</span>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- AI Analysis Signal -->
                    @if (analysis != null)
                    {
                        <div class="d-flex align-items-start gap-2 mb-3" style="padding: 10px 14px; background: rgba(139, 92, 246, 0.04); border-radius: 10px; border: 1px solid rgba(139, 92, 246, 0.08);">
                            <span style="font-size: 1.1rem;">🧠</span>
                            <div>
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span style="font-size: 0.72rem; color: var(--accent-purple); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">AI Phân tích</span>
                                    @{
                                        var signalClass = analysis.AiSignal switch
                                        {
                                            "SELL" => "sell",
                                            "PARTIAL" => "watch",
                                            "WATCH" => "watch",
                                            "HOLD" => "hold",
                                            "CAUTION" => "caution",
                                            _ => "none"
                                        };
                                        var signalLabel = analysis.AiSignal switch
                                        {
                                            "SELL" => "🔴 BÁN",
                                            "PARTIAL" => "🟠 BÁN BỚT",
                                            "WATCH" => "🟡 THEO DÕI SÁT",
                                            "HOLD" => "🔵 GIỮ",
                                            "CAUTION" => "🟠 CẢNH BÁO",
                                            _ => "⚪ CHƯA CÓ"
                                        };
                                    }
                                    <span class="ai-signal @signalClass">@signalLabel</span>
                                </div>
                                <div class="ai-reason-text">@analysis.AiReason</div>
                                <div class="ai-reason-text" style="color: var(--accent-cyan);">
                                    Hạn mức vốn cho mã: @analysis.FixedBudget.ToString("N0") đ | Đã dùng: @analysis.InvestedAmount.ToString("N0") đ | Còn lại: @analysis.RemainingBudget.ToString("N0") đ
                                </div>
                                <div class="ai-reason-text" style="color: var(--accent-amber);">
                                    Có thể mua thêm tối đa: @analysis.SuggestedAddAmount.ToString("N0") đ (@analysis.SuggestedAddQuantity.ToString("N0") CP theo giá hiện tại)
                                </div>
                                <div class="ai-reason-text" style="color: var(--accent-green);">
                                    Gợi ý mua thêm: chỉ giải ngân khi giá điều chỉnh về vùng an toàn và tổng vốn sau mua vẫn không vượt @analysis.FixedBudget.ToString("N0") đ.
                                </div>
                                @if (analysis.CurrentPnL > 0 && analysis.ProgressPercent >= 50)
                                {
                                    <div class="ai-reason-text" style="color: var(--accent-amber);">
                                        Gợi ý chốt bớt: có thể bán một phần để khóa lãi, giữ lại phần nhỏ làm vị thế tiếp tục quay vòng.
                                    </div>
                                }
                                @if (analysis.CanPartialSell)
                                {
                                    <div class="ai-reason-text" style="color: var(--accent-green);">
                                        Đề xuất bán bớt: @analysis.SuggestedSellQuantity.ToString("N0") CP, khóa khoảng @analysis.SuggestedSellProfit.ToString("N0") đ, còn lại @((pos.Quantity - analysis.SuggestedSellQuantity).ToString("N0")) CP.
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }

                    <!-- Target Settings Form -->
                    <form asp-action="UpdateRisk" method="post">
                        <input type="hidden" name="id" value="@pos.Id" />
                        <div class="d-flex flex-wrap align-items-end gap-3">
                            <div>
                                <label class="d-block" style="font-size: 0.72rem; color: var(--accent-cyan); font-weight: 600; margin-bottom: 4px;">
                                    Hạn mức vốn cho mã (đ)
                                </label>
                                <input type="hidden" name="budgetAmount" id="budgetAmount_@pos.Id" value="@(pos.BudgetAmount?.ToString("0") ?? pref.AmountPerTrade.ToString("0"))" />
                                <input type="text" id="budgetAmountDisplay_@pos.Id" value="@(pos.BudgetAmount?.ToString("N0") ?? pref.AmountPerTrade.ToString("N0"))"
                                       class="risk-input number-format" data-target="budgetAmount_@pos.Id" placeholder="VD: 1000000" />
                            </div>
                            <div>
                                <label class="d-block" style="font-size: 0.72rem; color: var(--accent-amber); font-weight: 600; margin-bottom: 4px;">
                                    🎯 MỤC TIÊU LỢI NHUẬN SAU BÁN (đ)
                                </label>
                                <input type="hidden" name="targetProfitAmount" id="targetProfitAmount_@pos.Id" value="@(pos.TargetProfitAmount?.ToString("0") ?? "")" />
                                <input type="text" id="targetProfitAmountDisplay_@pos.Id" value="@(pos.TargetProfitAmount?.ToString("N0") ?? "")"
                                        class="risk-input target-input number-format" data-target="targetProfitAmount_@pos.Id" placeholder="Lãi muốn đạt, VD: 100000" />
                            </div>
                            <div>
                                <label class="d-block" style="font-size: 0.72rem; color: var(--accent-green); font-weight: 500; margin-bottom: 4px;">
                                    Chốt lời - giá bán tự động
                                </label>
                                <input type="hidden" name="takeProfit" id="takeProfit_@pos.Id" value="@(pos.TakeProfitPrice?.ToString("0") ?? "")" />
                                <input type="text" id="takeProfitDisplay_@pos.Id" value="@(pos.TakeProfitPrice?.ToString("N0") ?? "")"
                                       class="risk-input text-success number-format" data-target="takeProfit_@pos.Id" placeholder="Tự động" />
                            </div>
                            <div>
                                <label class="d-block" style="font-size: 0.72rem; color: var(--accent-red); font-weight: 500; margin-bottom: 4px;">
                                    Cắt lỗ - số tiền lỗ tối đa
                                </label>
                                <input type="hidden" name="stopLoss" id="stopLoss_@pos.Id" value="@(pos.StopLossPrice?.ToString("0") ?? "")" />
                                <input type="text" id="stopLossDisplay_@pos.Id" value="@(pos.StopLossPrice?.ToString("N0") ?? "")"
                                       class="risk-input text-danger number-format" data-target="stopLoss_@pos.Id" placeholder="Giá cắt" />
                            </div>
                            <div>
                                <label class="d-block" style="font-size: 0.72rem; color: var(--accent-purple); font-weight: 600; margin-bottom: 4px;">
                                    ⏳ THỜI GIAN GIỮ (ngày)
                                </label>
                                <input type="number" name="expectedHoldDays" value="@(pos.ExpectedHoldDays)"
                                       class="risk-input text-white" style="width: 100px; border-color: rgba(139, 92, 246, 0.3);" placeholder="VD: 15" min="1" />
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                <button type="submit" class="btn-save-target" title="Lưu mục tiêu & rủi ro">
                                    💾 Lưu mục tiêu
                                </button>
                                <button type="button" onclick="showAdvancedAnalysis(@pos.Id)" class="btn-save-target" style="background: rgba(139, 92, 246, 0.18); border-color: rgba(139, 92, 246, 0.35); color: #c084fc;" title="Phân tích dữ liệu nâng cao & dự đoán timing">
                                    🧠 Phân tích nâng cao
                                </button>
                                @if (pos.Quantity > 0)
                                {
                                    <button type="button" onclick="buyMorePosition(@pos.Id, '@pos.Symbol')" class="btn-save-target" title="Mua thêm từ nguồn cố định">
                                        ➕ Mua thêm
                                    </button>
                                    <button type="button" onclick="partialSellPosition(@pos.Id, @currentPrice, '@pos.Symbol', @(analysis?.SuggestedSellQuantity ?? 0))" class="btn-save-target" style="background: rgba(245, 158, 11, 0.18); border-color: rgba(245, 158, 11, 0.35); color: #fcd34d;" title="Bán một phần để khóa lãi">
                                        🟠 Bán bớt
                                    </button>
                                    <button type="button" onclick="sellPosition(@pos.Id, @currentPrice, '@pos.Symbol')" class="btn-sell">
                                        📤 Bán
                                    </button>
                                }
                            </div>
                        </div>
                        @if (!hasTarget)
                        {
                            <div class="mt-2" style="font-size: 0.75rem; color: var(--text-secondary); font-style: italic;">
                                💡 Nhập số lãi mong muốn sau khi bán cho mã @pos.Symbol. AI sẽ tự động tính giá chốt lời từ số tiền này và theo dõi tiến độ.
                            </div>
                        }
                    </form>

                    <!-- Lịch sử giao dịch chi tiết & Phân tích thời điểm -->
                    @{
                        var symbolTransactions = (ViewBag.Transactions as List<StockTransaction> ?? new List<StockTransaction>())
                            .Where(t => t.Symbol == pos.Symbol)
                            .OrderBy(t => t.TransactionDate)
                            .ToList();
                    }
                    @if (symbolTransactions.Any())
                    {
                        <div class="transaction-section mb-3 mt-3">
                            <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                                <div class="d-flex align-items-center gap-2">
                                    <span style="font-size: 1.1rem;">📜</span>
                                    <span style="font-size: 0.82rem; color: var(--accent-cyan); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Lịch sử giao dịch cụ thể & Timing</span>
                                </div>
                                <div class="d-flex align-items-center gap-3 text-secondary" style="font-size: 0.78rem;">
                                    @{
                                        var buysCount = symbolTransactions.Where(t => t.TransactionType == "BUY").Sum(t => t.Quantity);
                                        var sellsCount = symbolTransactions.Where(t => t.TransactionType == "SELL").Sum(t => t.Quantity);
                                    }
                                    <span>Tổng mua: <strong class="text-white">@buysCount.ToString("N0") CP</strong></span>
                                    <span>Tổng bán: <strong class="text-white">@sellsCount.ToString("N0") CP</strong></span>
                                    <span>Hiện còn: <strong class="text-info">@((buysCount - sellsCount).ToString("N0")) CP</strong></span>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm table-dark table-hover m-0 align-middle" style="font-size: 0.82rem; border-color: rgba(255,255,255,0.05);">
                                    <thead>
                                        <tr class="text-secondary" style="font-size: 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.08);">
                                            <th>Ngày giao dịch</th>
                                            <th>Loại lệnh</th>
                                            <th class="text-end">Số lượng</th>
                                            <th class="text-end">Giá khớp</th>
                                            <th class="text-end">Tổng giá trị</th>
                                            <th class="text-end">Lãi/Lỗ hiện thực</th>
                                            <th class="text-center">Đánh giá Timing</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var tx in symbolTransactions)
                                        {
                                            var isBuy = tx.TransactionType == "BUY";
                                            var badgeClass = isBuy ? "bg-success" : "bg-warning text-dark";
                                            var actionText = isBuy ? "MUA" : "BÁN";
                                            var timingClass = "";
                                            var timingLabel = "";
                                            if (tx.TimingScore.HasValue)
                                            {
                                                timingClass = tx.TimingScore.Value >= 80m ? "text-success" : tx.TimingScore.Value >= 50m ? "text-warning" : "text-danger";
                                                timingLabel = $"{tx.TimingScore.Value:N1}% (" + (tx.TimingScore.Value >= 80m ? "Tốt" : tx.TimingScore.Value >= 50m ? "TB" : "Kém") + ")";
                                            }
                                            else
                                            {
                                                timingLabel = "-";
                                            }
                                            <tr>
                                                <td class="text-secondary">@tx.TransactionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td><span class="badge @badgeClass" style="font-size: 0.7rem; padding: 3px 6px;">@actionText</span></td>
                                                <td class="text-end font-monospace">@tx.Quantity.ToString("N0") CP</td>
                                                <td class="text-end font-monospace">@tx.Price.ToString("N0") đ</td>
                                                <td class="text-end font-monospace">@tx.TotalAmount.ToString("N0") đ</td>
                                                <td class="text-end font-monospace @(tx.PnlAmount >= 0 ? "pnl-positive" : "pnl-negative")">
                                                    @(tx.PnlAmount.HasValue ? (tx.PnlAmount.Value >= 0 ? "+" : "") + tx.PnlAmount.Value.ToString("N0") + " đ" : "-")
                                                </td>
                                                <td class="text-center fw-bold @timingClass">@timingLabel</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }

    <!-- Danh Mục Vị Thế Đã Đóng / Lịch Sử Đầu Tư -->
    <div class="glass-card mt-4 mb-4">
        <h4 class="fw-bold text-white mb-3" style="font-size: 1.1rem;"><span class="gradient-text">Danh mục vị thế đã đóng / Lịch sử đầu tư (Chi tiết giao dịch)</span></h4>
        @{
            var closedPositions = ViewBag.ClosedPositions as List<TradePosition> ?? new List<TradePosition>();
        }
        @if (!closedPositions.Any())
        {
            <p class="text-secondary small mb-0">Chưa có vị thế nào được chốt (đã đóng).</p>
        }
        else
        {
            <div class="d-flex flex-column gap-4">
                @foreach (var cp in closedPositions)
                {
                    var symbolTransactions = (ViewBag.Transactions as List<StockTransaction> ?? new List<StockTransaction>())
                        .Where(t => t.Symbol == cp.Symbol)
                        .OrderBy(t => t.TransactionDate)
                        .ToList();

                    <div class="position-card">
                        <div class="position-header" style="background: rgba(255,255,255,0.01); padding: 16px 20px;">
                            <div class="d-flex align-items-center gap-3">
                                <div>
                                    <span class="fw-bold text-white" style="font-size: 1.15rem;">@cp.Symbol</span>
                                    <span class="source-badge bg-secondary text-white-50 ms-2" style="font-size: 0.73rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; padding: 4px 8px; display: inline-block;">
                                        ⚪ Đã tất toán (Số CP còn lại: 0 CP)
                                    </span>
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="@(cp.PnL >= 0 ? "pnl-positive" : "pnl-negative")" style="font-size: 1.25rem; font-weight: 700;">
                                    @(cp.PnL >= 0 ? "+" : "")@cp.PnL.ToString("N0") đ
                                </div>
                                <div class="small text-secondary" style="font-size: 0.82rem;">
                                    Lãi/Lỗ thực tế chốt
                                </div>
                            </div>
                        </div>
                        <div class="position-body" style="padding: 16px 20px;">
                            <div class="stat-grid mb-3">
                                <div class="stat-item">
                                    <div class="stat-label" style="font-size: 0.72rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em;">Số CP còn lại</div>
                                    <div class="stat-value text-white-50" style="font-size: 0.95rem; font-weight: 600; margin-top: 2px;">0 CP</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-label" style="font-size: 0.72rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em;">Giá mua trung bình</div>
                                    <div class="stat-value text-white-50" style="font-size: 0.95rem; font-weight: 600; margin-top: 2px;">@cp.EntryPrice.ToString("N0") đ</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-label" style="font-size: 0.72rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em;">Thời gian nắm giữ</div>
                                    <div class="stat-value text-white-50" style="font-size: 0.95rem; font-weight: 600; margin-top: 2px;">@((DateTime.Now.Date - cp.EntryDate.Date).Days) ngày</div>
                                </div>
                            </div>

                            <!-- Lịch sử giao dịch cụ thể của mã (Vị thế đã đóng) -->
                            @if (symbolTransactions.Any())
                            {
                                <div class="transaction-section mb-2 mt-2" style="background: rgba(255, 255, 255, 0.015); border: 1px solid var(--border-color); border-radius: 12px; padding: 16px;">
                                    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <span style="font-size: 1.1rem;">📜</span>
                                            <span style="font-size: 0.82rem; color: var(--accent-cyan); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Lịch sử giao dịch cụ thể & Timing</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-3 text-secondary" style="font-size: 0.78rem;">
                                            @{
                                                var buysCount = symbolTransactions.Where(t => t.TransactionType == "BUY").Sum(t => t.Quantity);
                                                var sellsCount = symbolTransactions.Where(t => t.TransactionType == "SELL").Sum(t => t.Quantity);
                                            }
                                            <span>Tổng mua: <strong class="text-white">@buysCount.ToString("N0") CP</strong></span>
                                            <span>Tổng bán: <strong class="text-white">@sellsCount.ToString("N0") CP</strong></span>
                                            <span>Hiện còn: <strong class="text-info">@((buysCount - sellsCount).ToString("N0")) CP</strong></span>
                                        </div>
                                    </div>
                                    <div class="table-responsive">
                                        <table class="table table-sm table-dark table-hover m-0 align-middle" style="font-size: 0.82rem; border-color: rgba(255,255,255,0.05);">
                                            <thead>
                                                <tr class="text-secondary" style="font-size: 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.08);">
                                                    <th>Ngày giao dịch</th>
                                                    <th>Loại lệnh</th>
                                                    <th class="text-end">Số lượng</th>
                                                    <th class="text-end">Giá khớp</th>
                                                    <th class="text-end">Tổng giá trị</th>
                                                    <th class="text-end">Lãi/Lỗ hiện thực</th>
                                                    <th class="text-center">Đánh giá Timing</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var tx in symbolTransactions)
                                                {
                                                    var isBuy = tx.TransactionType == "BUY";
                                                    var badgeClass = isBuy ? "bg-success" : "bg-warning text-dark";
                                                    var actionText = isBuy ? "MUA" : "BÁN";
                                                    var timingClass = "";
                                                    var timingLabel = "";
                                                    if (tx.TimingScore.HasValue)
                                                    {
                                                        timingClass = tx.TimingScore.Value >= 80m ? "text-success" : tx.TimingScore.Value >= 50m ? "text-warning" : "text-danger";
                                                        timingLabel = $"{tx.TimingScore.Value:N1}% (" + (tx.TimingScore.Value >= 80m ? "Tốt" : tx.TimingScore.Value >= 50m ? "TB" : "Kém") + ")";
                                                    }
                                                    else
                                                    {
                                                        timingLabel = "-";
                                                    }
                                                    <tr>
                                                        <td class="text-secondary">@tx.TransactionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                                        <td><span class="badge @badgeClass" style="font-size: 0.7rem; padding: 3px 6px;">@actionText</span></td>
                                                        <td class="text-end font-monospace">@tx.Quantity.ToString("N0") CP</td>
                                                        <td class="text-end font-monospace">@tx.Price.ToString("N0") đ</td>
                                                        <td class="text-end font-monospace">@tx.TotalAmount.ToString("N0") đ</td>
                                                        <td class="text-end font-monospace @(tx.PnlAmount >= 0 ? "pnl-positive" : "pnl-negative")">
                                                            @(tx.PnlAmount.HasValue ? (tx.PnlAmount.Value >= 0 ? "+" : "") + tx.PnlAmount.Value.ToString("N0") + " đ" : "-")
                                                        </td>
                                                        <td class="text-center fw-bold @timingClass">@timingLabel</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Bảng Lịch Sử Kế Hoạch Đầu Tư Đã Chạy -->
    <div class="glass-card mt-4 mb-4">
        <h4 class="fw-bold text-white mb-3" style="font-size: 1.1rem;"><span class="gradient-text">Lịch sử kế hoạch đầu tư đã chạy (Audit Trail)</span></h4>
        @{
            var historyPlans = ViewBag.HistoryPlans as List<InvestmentPlan> ?? new List<InvestmentPlan>();
        }
        @if (!historyPlans.Any())
        {
            <p class="text-secondary small mb-0">Chưa có lịch sử chạy kế hoạch đầu tư nào.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover m-0 align-middle" style="font-size: 0.82rem; border-color: rgba(255,255,255,0.05);">
                    <thead>
                        <tr class="text-secondary" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
                            <th>Ngày chạy</th>
                            <th>Thời hạn chu kỳ</th>
                            <th class="text-end">Vốn đầu tư</th>
                            <th class="text-end">Mục tiêu lãi</th>
                            <th class="text-end">Lũy kế lúc chạy</th>
                            <th class="text-end">Còn thiếu</th>
                            <th>Còn lại</th>
                            <th class="text-center">Xác suất AI</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-end">KQ thực tế</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var plan in historyPlans)
                        {
                            var statusBadgeClass = plan.Status switch
                            {
                                "Pending" => "bg-secondary text-white-50",
                                "Active" => "bg-primary text-white",
                                "Success" => "bg-success text-white",
                                "Failed" => "bg-danger text-white",
                                "Expired" => "bg-warning text-dark",
                                "CompletedEarly" => "bg-info text-dark",
                                _ => "bg-dark text-secondary"
                            };
                            var statusLabel = plan.Status switch
                            {
                                "Pending" => "Chờ xử lý",
                                "Active" => "Đang chạy",
                                "Success" => "Thành công",
                                "Failed" => "Thất bại",
                                "Expired" => "Hết hạn",
                                "CompletedEarly" => "Hoàn thành sớm",
                                _ => plan.Status
                            };
                            <tr>
                                <td class="text-secondary">@plan.RunDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@plan.StartDate.ToString("dd/MM/yyyy") - @plan.EndDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-end font-monospace">@plan.Capital.ToString("N0") đ</td>
                                <td class="text-end font-monospace text-warning">@plan.TargetProfit.ToString("N0") đ</td>
                                <td class="text-end font-monospace @(plan.ActualProfit >= 0 ? "pnl-positive" : "pnl-negative")">
                                    @(plan.ActualProfit >= 0 ? "+" : "")@plan.ActualProfit.ToString("N0") đ
                                </td>
                                <td class="text-end font-monospace text-secondary">@plan.RemainingProfitNeeded.ToString("N0") đ</td>
                                <td>@plan.DaysRemainingAtRun ngày</td>
                                <td class="text-center fw-bold" style="color: @(plan.SuccessProbability >= 80 ? "var(--accent-green)" : plan.SuccessProbability >= 50 ? "var(--accent-amber)" : "var(--accent-red)");">
                                    @plan.SuccessProbability.ToString("N1")%
                                </td>
                                <td class="text-center">
                                    <span class="badge @statusBadgeClass px-2 py-1" style="font-size: 0.7rem; border-radius: 4px;">@statusLabel</span>
                                </td>
                                <td class="text-end font-monospace">
                                    @if (plan.FinalProfit.HasValue)
                                    {
                                        <span class="@(plan.FinalProfit.Value >= 0 ? "pnl-positive" : "pnl-negative") fw-bold">
                                            @(plan.FinalProfit.Value >= 0 ? "+" : "")@plan.FinalProfit.Value.ToString("N0") đ
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <button type="button" onclick="showHistoricalPlanDetails(@plan.Id)" class="btn-save-target" style="padding: 4px 10px; font-size: 0.72rem;">
                                        🔍 Chi tiết
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Hidden form for selling -->
