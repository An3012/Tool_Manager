                            <th style="width: 10%;">PnL tích lũy</th>
                            <th style="width: 25%;">Hành động thực tế</th>
                        </tr>
                    </thead>
                    <tbody id="histDailyCalendarBody">
                        <!-- Dynamic JS injection -->
                    </tbody>
                </table>
            </div>
