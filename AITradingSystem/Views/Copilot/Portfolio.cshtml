        <!-- Rationale -->
        <div class="p-3 rounded mb-4" style="background: rgba(139, 92, 246, 0.015); border: 1px solid rgba(139, 92, 246, 0.05);">
            <div class="fw-bold text-white mb-1" style="font-size: 0.85rem; color: var(--accent-green) !important;">📊 Phân tích cơ sở & Quản trị rủi ro:</div>
            <p id="histRationale" class="m-0 text-secondary" style="font-size: 0.82rem; line-height: 1.5; font-style: italic;"></p>
        </div>

        <!-- Footer Buttons -->
