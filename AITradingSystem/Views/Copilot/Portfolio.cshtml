<!-- Loading Overlay toàn trang cho AI Plan -->
<div id="aiPlanLoadingOverlay" class="modal-overlay" style="display: @(ViewBag.PlanStatus == "Pending" ? "flex" : "none"); position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(9, 10, 15, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); z-index: 2000; align-items: center; justify-content: center; flex-direction: column;">
    <div class="text-center p-5 rounded-4" style="background: rgba(20, 22, 37, 0.8); border: 1px solid rgba(139, 92, 246, 0.2); max-width: 450px;">
        <div class="spinner-grow text-primary mb-4" style="width: 3.5rem; height: 3.5rem; background-color: var(--accent-purple);" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h4 class="fw-bold text-white mb-2">🧠 AI Trading Copilot</h4>
        <p id="loadingStatusText" class="text-secondary small mb-3">Đang kết nối AI Copilot và thu thập dữ liệu vị thế...</p>
        <div class="progress" style="height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px;">
            <div id="loadingProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 15%; background-color: var(--accent-purple); height: 100%;"></div>
        </div>
    </div>
</div>

<script>
    // Hiển thị loading overlay với text chạy động
    function showGlobalLoading() {
        const overlay = document.getElementById('aiPlanLoadingOverlay');
        overlay.style.display = 'flex';
        
        const texts = [
            "Đang thu thập dữ liệu vị thế và phân bổ ngân sách...",
            "Đang đóng băng snapshot danh mục đầu tư...",
            "Đang thiết lập kết nối bảo mật tới AI Copilot Engine...",
            "AI đang phân tích dải kỹ thuật cổ phiếu (RSI, Trend)...",
            "AI đang hoạch định điều phối ngân sách tối ưu cuối kỳ...",
            "AI đang tính toán xác suất đạt mục tiêu tổng thể...",
            "Đang hoàn thiện đề xuất giao dịch và lưu vào nhật ký..."
        ];
        
        let i = 0;
        const textEl = document.getElementById('loadingStatusText');
        const progressEl = document.getElementById('loadingProgressBar');
        
        const textInterval = setInterval(() => {
            if (i < texts.length) {
                textEl.innerText = texts[i];
                progressEl.style.width = ((i + 1) * 100 / texts.length) + '%';
                i++;
            } else {
                clearInterval(textInterval);
            }
        }, 3000);
    }

    // Polling trạng thái Pending của kế hoạch
    document.addEventListener('DOMContentLoaded', function () {
        const planStatus = "@ViewBag.PlanStatus";
        const planId = "@ViewBag.PlanId";
        
        if (planStatus === "Pending" && planId !== "0") {
            showGlobalLoading();
            
            const interval = setInterval(() => {
                fetch('/Copilot/CheckPlanStatus?id=' + planId)
                    .then(r => r.json())
                    .then(data => {
                        if (data.status !== "Pending") {
                            clearInterval(interval);
                            window.location.reload();
                        }
                    })
                    .catch(err => console.error("Lỗi polling: " + err));
            }, 3000);
        }
    });

    // Xem chi tiết kế hoạch lịch sử
    function showHistoricalPlanDetails(id) {
        const modal = document.getElementById('historicalPlanModal');
        modal.style.display = 'flex';
        
        // Reset fields
        document.getElementById('histRunDate').innerText = 'Đang tải...';
        document.getElementById('histAiVersion').innerText = '---';
        document.getElementById('histCapital').innerText = '-';
        document.getElementById('histTarget').innerText = '-';
        document.getElementById('histActual').innerText = '-';
        
        const statusEl = document.getElementById('histStatus');
        statusEl.innerText = '-';
        statusEl.className = 'badge';
        
        document.getElementById('histTimeline').innerText = '-';
        document.getElementById('histDaysRemaining').innerText = '-';
        document.getElementById('histProbability').innerText = '-';
        document.getElementById('histSummary').innerText = 'Đang tải phân tích...';
        document.getElementById('histActionsBody').innerHTML = '<tr><td colspan="3" class="text-center text-muted">Đang tải...</td></tr>';
        document.getElementById('histDailyCalendarBody').innerHTML = '<tr><td colspan="5" class="text-center text-muted">Đang tải...</td></tr>';
        document.getElementById('histContributionsContainer').innerHTML = '<span class="text-muted">Đang tải...</span>';
        document.getElementById('histRationale').innerText = 'Đang tải lập luận...';
        
        fetch('/Copilot/GetPlanDetails?id=' + id)
            .then(res => {
                if (!res.ok) throw new Error("Không thể tải chi tiết kế hoạch.");
                return res.json();
            })
            .then(data => {
                document.getElementById('histRunDate').innerText = data.runDateStr;
                document.getElementById('histAiVersion').innerText = data.aiVersion;
                document.getElementById('histCapital').innerText = data.capitalStr;
                document.getElementById('histTarget').innerText = data.targetProfitStr;
                document.getElementById('histActual').innerText = data.actualProfitStr;
                
                statusEl.innerText = data.status;
                let badgeClass = 'bg-secondary';
                if (data.status === 'Đang chạy') badgeClass = 'bg-primary';
                else if (data.status === 'Thành công') badgeClass = 'bg-success';
                else if (data.status === 'Thất bại') badgeClass = 'bg-danger';
                else if (data.status === 'Hết hạn') badgeClass = 'bg-warning text-dark';
                else if (data.status === 'Hoàn thành sớm') badgeClass = 'bg-info text-dark';
                statusEl.className = 'badge ' + badgeClass + ' px-2 py-1';
                
                document.getElementById('histTimeline').innerText = data.timelineStr;
                document.getElementById('histDaysRemaining').innerText = data.daysRemainingAtRun + ' ngày';
                document.getElementById('histProbability').innerText = data.successProbability.toFixed(1);
                document.getElementById('histSummary').innerText = data.summary;
                document.getElementById('histRationale').innerText = data.rationale;
                
                // Actions rendering
                let actionsHtml = '';
                if (data.actions && data.actions.length > 0) {
                    data.actions.forEach(act => {
                        actionsHtml += `
                            <tr>
                                <td class="fw-bold text-white">${act.ticker}</td>
                                <td><span class="badge" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); font-size: 0.72rem; color: #fff; padding: 3px 6px; display: inline-block;">${act.action}</span></td>
                                <td class="text-secondary">${act.description}</td>
                            </tr>
                        `;
                    });
                } else {
                    actionsHtml = '<tr><td colspan="3" class="text-muted small">Không có đề xuất giao dịch nào.</td></tr>';
                }
                document.getElementById('histActionsBody').innerHTML = actionsHtml;

                // Daily Calendar rendering
                let dailyCalendarHtml = '';
                if (data.dailyCalendar && data.dailyCalendar.length > 0) {
                    data.dailyCalendar.forEach(item => {
                        let badgeClass = 'bg-secondary';
                        if (item.actionType === 'MUA' || item.actionType === 'MUA THÊM') badgeClass = 'bg-success';
                        else if (item.actionType === 'BÁN') badgeClass = 'bg-danger';
                        else if (item.actionType === 'CƠ CẤU') badgeClass = 'bg-warning text-dark';
                        else if (item.actionType === 'TẤT TOÁN') badgeClass = 'bg-primary';
                        else if (item.actionType === 'SÀN ĐÓNG CỬA') badgeClass = 'bg-secondary';

                        let badgeHtml = (item.actionType !== 'GIỮ' && item.actionType !== 'SÀN ĐÓNG CỬA') 
                            ? `<span class="badge ${badgeClass} me-2" style="font-size: 0.65rem; padding: 3px 6px;">${item.actionType}</span>` 
                            : (item.actionType === 'GIỮ' ? `<span class="badge bg-secondary me-2" style="font-size: 0.65rem; padding: 3px 6px;">${item.actionType}</span>` : '');

                        let formattedDesc = item.description.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                        let targetClass = item.target.includes('+') ? 'pnl-positive fw-bold' : 'text-secondary';

                        dailyCalendarHtml += `
                            <tr>
                                <td class="text-white fw-bold">${item.date}</td>
                                <td class="text-secondary">${item.dayOfWeek}</td>
                                <td>${badgeHtml}${formattedDesc}</td>
                                <td class="${targetClass}">${item.target}</td>
                                <td class="text-info fw-bold">${item.cumulativePnL}</td>
                            </tr>
                        `;
                    });
                } else {
                    dailyCalendarHtml = '<tr><td colspan="5" class="text-muted small text-center">Không có lịch trình giao dịch nào.</td></tr>';
                }
                document.getElementById('histDailyCalendarBody').innerHTML = dailyCalendarHtml;
                
                // Contributions rendering
                let contribHtml = '';
                if (data.expectedContributions && data.expectedContributions.length > 0) {
                    data.expectedContributions.forEach(con => {
                        contribHtml += `
                            <div class="p-2 rounded" style="background: rgba(255, 255, 255, 0.015); border: 1px solid rgba(255, 255, 255, 0.03);">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-white" style="font-size: 0.82rem;">${con.ticker}</span>
                                    <span class="pnl-positive fw-bold" style="font-size: 0.82rem;">+${con.expectedProfit.toLocaleString()} đ</span>
                                </div>
                                <div class="text-secondary mt-1" style="font-size: 0.74rem;">${con.description}</div>
                            </div>
                        `;
                    });
                } else {
                    contribHtml = '<span class="text-muted small">Không có dự báo đóng góp.</span>';
                }
                document.getElementById('histContributionsContainer').innerHTML = contribHtml;
            })
            .catch(err => {
                console.error(err);
                document.getElementById('histSummary').innerText = 'Lỗi tải dữ liệu kế hoạch: ' + err.message;
            });
    }

    function closeHistoricalPlan() {
        document.getElementById('historicalPlanModal').style.display = 'none';
    }

    document.addEventListener('DOMContentLoaded', function () {
        const numberInputs = document.querySelectorAll('.number-format');
        
        numberInputs.forEach(input => {
            input.addEventListener('input', function (e) {
                let cursorPosition = this.selectionStart;
                let originalLength = this.value.length;
                
                // Loại bỏ tất cả ký tự không phải là số
                let cleanVal = this.value.replace(/\D/g, '');
                
                // Cập nhật giá trị số thực cho input hidden
                const targetId = this.getAttribute('data-target');
                if (targetId) {
                    const hiddenInput = document.getElementById(targetId);
                    if (hiddenInput) {
                        hiddenInput.value = cleanVal;
                    }
                }
                
                // Định dạng hiển thị bằng dấu phẩy
                let formattedVal = cleanVal ? parseInt(cleanVal, 10).toLocaleString('en-US') : '';
                this.value = formattedVal;
                
                // Giữ vị trí con trỏ chuột không bị nhảy về cuối
                let newLength = formattedVal.length;
                let diff = newLength - originalLength;
                let newCursorPosition = Math.max(0, cursorPosition + diff);
                this.setSelectionRange(newCursorPosition, newCursorPosition);
            });
            
            input.addEventListener('blur', function() {
                const targetId = this.getAttribute('data-target');
                if (targetId) {
                    const hiddenInput = document.getElementById(targetId);
                    if (hiddenInput && !this.value) {
                        hiddenInput.value = '';
                    }
                }
            });
        });
    });

    function sellPosition(id, price, symbol) {
        if (confirm('Bạn có chắc chắn muốn bán toàn bộ vị thế ' + symbol + ' với giá ' + price.toLocaleString() + ' đ?')) {
            document.getElementById('sellId').value = id;
            document.getElementById('sellPrice').value = price;
            document.getElementById('sellForm').submit();
        }
    }

    function buyMorePosition(id, symbol) {
        const fixedAmount = @((long)pref.AmountPerTrade);
        if (confirm('Mua thêm cho ' + symbol + ' với nguồn cố định ' + fixedAmount.toLocaleString() + ' đ?')) {
            document.getElementById('buyMoreId').value = id;
            document.getElementById('buyMoreForm').submit();
        }
    }

    function partialSellPosition(id, price, symbol, suggestedQty) {
        const defaultQty = suggestedQty && suggestedQty > 0 ? suggestedQty : 1;
        const qtyText = prompt('Nhập số cổ phiếu muốn bán bớt của ' + symbol + ' (gợi ý: ' + defaultQty + ')', defaultQty.toString());
        if (!qtyText) return;

        const sellQty = parseInt(qtyText.replace(/\D/g, ''), 10);
        if (!sellQty || sellQty <= 0) {
            alert('Số lượng không hợp lệ.');
            return;
        }

        if (confirm('Bán bớt ' + sellQty + ' CP ' + symbol + ' với giá ' + price.toLocaleString() + ' đ để khóa một phần lãi?')) {
            document.getElementById('partialSellId').value = id;
            document.getElementById('partialSellQuantity').value = sellQty;
            document.getElementById('partialSellPrice').value = price;
            document.getElementById('partialSellForm').submit();
        }
    }

    function showAdvancedAnalysis(id) {
        const modal = document.getElementById('advancedAnalysisModal');
        modal.style.display = 'flex';
        
        // Reset modal fields
        document.getElementById('modalSymbol').innerText = 'Đang tải...';
        document.getElementById('modalQty').innerText = '-';
        document.getElementById('modalEntryPrice').innerText = '-';
        document.getElementById('modalCurrentPrice').innerText = '-';
        document.getElementById('modalPnL').innerText = '-';
        document.getElementById('modalAiSignal').innerText = '...';
        document.getElementById('modalStrategy').innerText = '...';
        document.getElementById('modalRationale').innerText = 'Đang chạy mô hình AI phân tích dải giá & đối chiếu lịch sử giao dịch...';
        
        // Reset suggestions
        document.getElementById('modalSellTiming').innerText = '--';
        document.getElementById('modalSellTp').innerText = '--';
        document.getElementById('modalSellSl').innerText = '--';
        document.getElementById('modalSellDesc').innerText = '--';
        document.getElementById('modalPartialSellTiming').innerText = '--';
        document.getElementById('modalPartialSellQty').innerText = '--';
        document.getElementById('modalPartialSellVal').innerText = '--';
        document.getElementById('modalPartialSellProfit').innerText = '--';
        document.getElementById('modalPartialSellDesc').innerText = '--';
        document.getElementById('modalPartialBuyTiming').innerText = '--';
        document.getElementById('modalPartialBuyLimit').innerText = '--';
        document.getElementById('modalPartialBuyQty').innerText = '--';
        document.getElementById('modalPartialBuyVal').innerText = '--';
        document.getElementById('modalPartialBuyDesc').innerText = '--';
        
        document.getElementById('modalBtnBuy').style.display = 'none';
        document.getElementById('modalBtnPartialSell').style.display = 'none';
        document.getElementById('modalBtnSell').style.display = 'none';
        document.getElementById('modalHistoryTimingRow').style.display = 'none';
        
        // Fetch data
        fetch('/Copilot/AdvancedAnalysis?id=' + id)
            .then(response => {
                if (!response.ok) throw new Error('Không thể tải phân tích.');
                return response.json();
            })
            .then(data => {
                document.getElementById('modalSymbol').innerText = data.symbol;
                document.getElementById('modalQty').innerText = data.quantity.toLocaleString();
                document.getElementById('modalEntryPrice').innerText = data.entryPrice.toLocaleString() + ' đ';
                document.getElementById('modalCurrentPrice').innerText = data.currentPrice.toLocaleString() + ' đ';
                
                // PnL formatting
                const pnlEl = document.getElementById('modalPnL');
                pnlEl.innerText = (data.pnL >= 0 ? '+' : '') + data.pnL.toLocaleString() + ' đ (' + data.pnlPercent.toFixed(2) + '%)';
                pnlEl.className = 'fw-bold ' + (data.pnL >= 0 ? 'pnl-positive' : 'pnl-negative');
                
                // AI signal badge color
                const signalEl = document.getElementById('modalAiSignal');
                signalEl.innerText = data.aiSignal;
                signalEl.className = 'ai-signal px-3 py-1-5';
                if (data.aiSignal === 'SELL') {
                    signalEl.style.background = 'rgba(239, 68, 68, 0.2)';
                    signalEl.style.color = 'var(--accent-red)';
                } else if (data.aiSignal === 'BUY') {
                    signalEl.style.background = 'rgba(16, 185, 129, 0.2)';
                    signalEl.style.color = 'var(--accent-green)';
                } else {
                    signalEl.style.background = 'rgba(59, 130, 246, 0.2)';
                    signalEl.style.color = 'var(--accent-blue)';
                }
                
                document.getElementById('modalStrategy').innerText = data.strategyApplied;
                document.getElementById('modalRationale').innerText = data.aiRationale;
                
                // Sell suggestion
                document.getElementById('modalSellTiming').innerText = data.sellSuggestion.timing;
                document.getElementById('modalSellTp').innerText = data.sellSuggestion.targetPrice.toLocaleString() + ' đ';
                document.getElementById('modalSellSl').innerText = data.sellSuggestion.stopLossPrice.toLocaleString() + ' đ';
                document.getElementById('modalSellDesc').innerText = data.sellSuggestion.description;
                
                // Partial sell suggestion
                document.getElementById('modalPartialSellTiming').innerText = data.partialSellSuggestion.timing;
                document.getElementById('modalPartialSellQty').innerText = data.partialSellSuggestion.quantity.toLocaleString();
                document.getElementById('modalPartialSellVal').innerText = data.partialSellSuggestion.estimatedValue.toLocaleString() + ' đ';
                document.getElementById('modalPartialSellProfit').innerText = (data.partialSellSuggestion.estimatedProfit >= 0 ? '+' : '') + data.partialSellSuggestion.estimatedProfit.toLocaleString() + ' đ';
                document.getElementById('modalPartialSellDesc').innerText = data.partialSellSuggestion.description;
                
                // Partial buy suggestion
                document.getElementById('modalPartialBuyTiming').innerText = data.partialBuySuggestion.timing;
                document.getElementById('modalPartialBuyLimit').innerText = data.partialBuySuggestion.remainingBudget.toLocaleString() + ' đ';
                document.getElementById('modalPartialBuyQty').innerText = data.partialBuySuggestion.suggestedQuantity.toLocaleString();
                document.getElementById('modalPartialBuyVal').innerText = data.partialBuySuggestion.suggestedValue.toLocaleString() + ' đ';
                document.getElementById('modalPartialBuyDesc').innerText = data.partialBuySuggestion.description;
                
                // Average historical timing score
                const timingRow = document.getElementById('modalHistoryTimingRow');
                const avgTimingScoreEl = document.getElementById('modalAvgTimingScore');
                if (data.avgTimingScore !== null) {
                    avgTimingScoreEl.innerText = data.avgTimingScore.toFixed(1) + '%';
                    timingRow.style.display = 'block';
                } else {
                    timingRow.style.display = 'none';
                }

                // Modal buttons logic
                const btnBuy = document.getElementById('modalBtnBuy');
                const btnPartialSell = document.getElementById('modalBtnPartialSell');
                const btnSell = document.getElementById('modalBtnSell');

                if (!data.isAiTrade) {
                    btnBuy.style.display = data.partialBuySuggestion.suggestedQuantity > 0 ? 'inline-block' : 'none';
                    btnBuy.onclick = function() {
                        closeAdvancedAnalysis();
                        buyMorePosition(id, data.symbol);
                    };

                    btnPartialSell.style.display = data.pnL > 0 && data.partialSellSuggestion.quantity > 0 ? 'inline-block' : 'none';
                    btnPartialSell.onclick = function() {
                        closeAdvancedAnalysis();
                        partialSellPosition(id, data.currentPrice, data.symbol, data.partialSellSuggestion.quantity);
                    };

                    btnSell.style.display = 'inline-block';
                    btnSell.onclick = function() {
                        closeAdvancedAnalysis();
                        sellPosition(id, data.currentPrice, data.symbol);
                    };
                } else {
                    btnBuy.style.display = 'none';
                    btnPartialSell.style.display = 'none';
                    btnSell.style.display = 'none';
                }
            })
            .catch(error => {
                console.error(error);
                document.getElementById('modalRationale').innerText = 'Không thể tải phân tích dữ liệu nâng cao. Lỗi: ' + error.message;
            });
    }

    function closeAdvancedAnalysis() {
        document.getElementById('advancedAnalysisModal').style.display = 'none';
    }
</script>
