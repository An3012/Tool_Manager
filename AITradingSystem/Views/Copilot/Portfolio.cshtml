            <!-- Contributions -->
            <div class="col-md-5">
                <div class="p-3 rounded h-100" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05);">
                    <div class="fw-bold text-white mb-2" style="font-size: 0.85rem; color: var(--accent-amber) !important;">💰 Dự báo đóng góp lợi nhuận:</div>
                    <div id="histContributionsContainer" class="d-flex flex-column gap-2">
                        <!-- Dynamic JS injection -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Lịch trình giao dịch tối ưu từng ngày (Daily Action Calendar) cho kế hoạch lịch sử -->
