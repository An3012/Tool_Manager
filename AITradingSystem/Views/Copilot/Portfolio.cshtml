    <div class="modal-glass-card" style="background: rgba(20, 22, 40, 0.95); border: 1px solid rgba(139, 92, 246, 0.25); border-radius: 20px; width: 90%; max-width: 800px; max-height: 85vh; overflow-y: auto; padding: 30px; box-shadow: 0 20px 50px rgba(0,0,0,0.6); position: relative; color: var(--text-primary);">
        
