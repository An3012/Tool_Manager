            <p id="histSummary" class="m-0 text-secondary" style="font-size: 0.85rem; line-height: 1.5;"></p>
        </div>

        <div class="row g-3 mb-4">
            <!-- Actions Table -->
            <div class="col-md-7">
                <div class="p-3 rounded h-100" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05);">
                    <div class="fw-bold text-white mb-2" style="font-size: 0.85rem; color: var(--accent-purple) !important;">🔄 Đề xuất điều chuyển vốn & Giao dịch:</div>
                    <div class="table-responsive">
                        <table class="table table-sm table-dark table-hover m-0" style="font-size: 0.8rem; border-color: rgba(255,255,255,0.03);">
                            <thead>
                                <tr class="text-secondary" style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                    <th>Mã CP</th>
                                    <th>Hành động</th>
                                    <th>Chi tiết điều chuyển vốn</th>
