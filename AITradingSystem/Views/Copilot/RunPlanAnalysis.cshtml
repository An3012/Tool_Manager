@using AITradingSystem.Models
@using AITradingSystem.Controllers
@{
    ViewData["Title"] = "Chạy Phân Tích Kế Hoạch - DNSE AI";
    var globalPlan = ViewBag.GlobalPlan as AITradingSystem.Services.GlobalPortfolioPlanResult;
    var positions = ViewBag.Positions as List<TradePosition> ?? new List<TradePosition>();
    var stocks = ViewBag.Stocks as List<StockViewModel> ?? new List<StockViewModel>();
    var pref = (ViewBag.Preference as UserPreference) ?? new UserPreference();
    var totalPnL = (decimal?)ViewBag.TotalPnL ?? 0;
    var analysisMap = ViewBag.AnalysisMap as Dictionary<int, PositionAnalysis> ?? new Dictionary<int, PositionAnalysis>();
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --bg-dark: #090a0f;
        --card-bg: rgba(20, 22, 37, 0.6);
        --border-color: rgba(255, 255, 255, 0.08);
        --text-primary: #f3f4f6;
        --text-secondary: #9ca3af;
        --accent-green: #10b981;
        --accent-red: #ef4444;
        --accent-purple: #8b5cf6;
        --accent-blue: #3b82f6;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-primary);
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .plan-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .plan-header {
        background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-purple) 100%);
        padding: 2rem;
        border-radius: 12px;
        margin-bottom: 2rem;
        box-shadow: 0 8px 32px rgba(59, 130, 246, 0.2);
    }

    .plan-title {
        font-size: 2rem;
        font-weight: 700;
        margin: 0 0 0.5rem 0;
    }

    .plan-probability {
        font-size: 1.1rem;
        opacity: 0.95;
    }

    .plan-section {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--accent-blue);
    }

    .action-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.03);
        border-left: 3px solid var(--accent-green);
        border-radius: 4px;
        margin-bottom: 0.75rem;
    }

    .action-ticker {
        font-weight: 600;
        color: var(--accent-blue);
        min-width: 80px;
    }

    .action-type {
        background: var(--accent-green);
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .action-type.sell {
        background: var(--accent-red);
    }

    .action-description {
        flex: 1;
        margin-left: 1rem;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .contribution-item {
        padding: 1rem;
        background: rgba(16, 185, 129, 0.1);
        border-left: 3px solid var(--accent-green);
        border-radius: 4px;
        margin-bottom: 0.75rem;
    }

    .contribution-ticker {
        font-weight: 600;
        color: var(--accent-blue);
    }

    .contribution-profit {
        color: var(--accent-green);
        font-weight: 600;
        font-size: 1.1rem;
    }

    .contribution-description {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-top: 0.5rem;
    }

    .btn-group {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background: var(--accent-blue);
        color: white;
    }

    .btn-primary:hover {
        background: #2563eb;
        transform: translateY(-2px);
    }

    .btn-secondary {
        background: rgba(255, 255, 255, 0.1);
        color: var(--text-primary);
        border: 1px solid var(--border-color);
    }

    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.15);
    }

    .rationale-box {
        background: rgba(59, 130, 246, 0.1);
        border-left: 4px solid var(--accent-blue);
        padding: 1rem;
        border-radius: 6px;
        margin-top: 1rem;
    }

    .rationale-title {
        color: var(--accent-blue);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .rationale-text {
        color: var(--text-secondary);
        line-height: 1.6;
    }
</style>

<div class="plan-container">
    @if (globalPlan != null)
    {
        <div class="plan-header">
            <div class="plan-title">📊 Kế Hoạch Tối Ưu Danh Mục</div>
            <div class="plan-probability">
                ✅ Xác suất thành công: <strong>@globalPlan.SuccessProbability%</strong>
            </div>
        </div>

        <div class="plan-section">
            <div class="section-title">📋 Tóm Tắt Kế Hoạch</div>
            <p>@globalPlan.PlanSummary</p>
            <div class="rationale-box">
                <div class="rationale-title">💡 Lý Thuyết:</div>
                <div class="rationale-text">@globalPlan.Rationale</div>
            </div>
        </div>

        @if (globalPlan.Actions != null && globalPlan.Actions.Any())
        {
            <div class="plan-section">
                <div class="section-title">🎯 Hành Động Đề Xuất</div>
                @foreach (var action in globalPlan.Actions)
                {
                    <div class="action-item">
                        <div class="action-ticker">@action.Ticker</div>
                        <div class="action-type @(action.Action.Contains("BÁN") ? "sell" : "")">
                            @action.Action
                        </div>
                        <div class="action-description">@action.Description</div>
                    </div>
                }
            </div>
        }

        @if (globalPlan.ExpectedContributions != null && globalPlan.ExpectedContributions.Any())
        {
            <div class="plan-section">
                <div class="section-title">💰 Lợi Nhuận Kỳ Vọng</div>
                @foreach (var contrib in globalPlan.ExpectedContributions)
                {
                    <div class="contribution-item">
                        <div class="contribution-ticker">@contrib.Ticker</div>
                        <div class="contribution-profit">
                            +@contrib.ExpectedProfit.ToString("N0") đ
                        </div>
                        <div class="contribution-description">@contrib.Description</div>
                    </div>
                }
            </div>
        }

        <div class="btn-group">
            <form asp-action="Portfolio" method="get" class="m-0">
                <button type="submit" class="btn btn-primary">👁️ Xem Danh Mục Chi Tiết</button>
            </form>
            <form asp-action="Index" method="get" class="m-0">
                <button type="submit" class="btn btn-secondary">🏠 Quay Lại Trang Chủ</button>
            </form>
        </div>
    }
    else
    {
        <div class="plan-section">
            <p>❌ Không thể tạo kế hoạch. Vui lòng thử lại.</p>
            <div class="btn-group">
                <form asp-action="Portfolio" method="get" class="m-0">
                    <button type="submit" class="btn btn-secondary">← Quay Lại</button>
                </form>
            </div>
        </div>
    }
</div>
