@using AITradingSystem.Models
@{
    ViewData["Title"] = "Cấu hình & Tài khoản - DNSE AI";
    var pref = (ViewBag.Preference as UserPreference) ?? new UserPreference();
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --bg-dark: #090a0f;
        --card-bg: rgba(20, 22, 37, 0.6);
        --border-color: rgba(255, 255, 255, 0.08);
        --text-primary: #f3f4f6;
        --text-secondary: #9ca3af;
        --accent-green: #10b981;
        --accent-red: #ef4444;
        --accent-purple: #8b5cf6;
        --accent-blue: #3b82f6;
        --accent-amber: #f59e0b;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-primary);
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .glass-card {
        background: var(--card-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    }

    .gradient-text {
        background: linear-gradient(135deg, #a78bfa 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .custom-input {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        border-radius: 8px;
        padding: 10px;
    }

    .custom-input:focus {
        background: rgba(255, 255, 255, 0.08);
        color: var(--text-primary);
        border-color: var(--accent-purple);
        box-shadow: 0 0 0 0.25rem rgba(139, 92, 246, 0.25);
    }

    .custom-label {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 6px;
    }

    .btn-gradient {
        background: linear-gradient(135deg, var(--accent-purple) 0%, var(--accent-blue) 100%);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px 24px;
        font-weight: 600;
        transition: opacity 0.2s;
    }

    .btn-gradient:hover {
        opacity: 0.9;
        color: white;
    }

    .section-title {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-amber);
        margin-bottom: 12px;
    }
</style>

<script>
    const input1 = document.getElementById("TargetAmount");
    input1.addEventListener("input", function () {
        let value = this.value.replace(/\D/g, "");

        if (value === "") {
            this.value = "";
            return;
        }

        this.value = Number(value).toLocaleString("vi-VN");
    });
    
    const input2 = document.getElementById("AmountPerTrade");
    input2.addEventListener("input", function () {
        let value = this.value.replace(/\D/g, "");

        if (value === "") {
            this.value = "";
            return;
        }

        this.value = Number(value).toLocaleString("vi-VN");
    });
</script>
<div class="container py-5">
    <div class="mb-5">
        <h1 class="fw-bold mb-2"><span class="gradient-text">Cấu hình & Liên kết</span></h1>
        <p class="text-secondary">Quản lý tài khoản DNSE và nhập mục tiêu lợi nhuận theo tiền cho từng lệnh.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-opacity-10 border-success text-success alert-dismissible fade show mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="glass-card h-100">
                <h3 class="h5 mb-4 fw-bold text-white d-flex align-items-center gap-2">
                    <span class="text-primary">⚙️</span> Cấu hình mục tiêu tiền
                </h3>

                <form asp-action="SavePreferences" method="post" class="d-flex flex-column gap-4">
                    <input type="hidden" name="Id" value="@pref.Id" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="custom-label">Phân tiền mỗi lệnh (đ)</label>
                            <input type="text" 
                            id="AmountPerTrade" 
                            name="AmountPerTrade" 
                            value="@pref.AmountPerTrade.ToString("N0").Replace(",", ".")" 
                            class="form-control custom-input" />
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label">Mục tiêu lợi nhuận (đ)</label>
                            <input type="text"
                                id="TargetAmount"
                                name="TargetAmount"
                                value="@pref.TargetAmount.ToString("N0").Replace(",", ".")"
                                class="form-control custom-input" />
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="custom-label">Ngày bắt đầu kế hoạch</label>
                            <input type="date" name="PlanStartDate" value="@(pref.PlanStartDate?.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))" class="form-control custom-input" />
                        </div>
                    </div>

                    <div>
                        <label class="custom-label">Thời gian đầu tư</label>
                        <input type="text" name="InvestmentHorizon" value="@pref.InvestmentHorizon" class="form-control custom-input" placeholder="Ví dụ: Short-term (T+2.5)" />
                    </div>

                    <div>
                        <label class="custom-label">Khẩu vị rủi ro</label>
                        <select name="RiskTolerance" class="form-select custom-input">
                            <option value="Low" selected="@(pref.RiskTolerance == "Low")">Thấp</option>
                            <option value="Medium" selected="@(pref.RiskTolerance == "Medium")">Trung bình</option>
                            <option value="High" selected="@(pref.RiskTolerance == "High")">Cao</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-gradient w-100 mt-2">💾 Thêm cấu hình mục tiêu mới</button>
                </form>
            </div>
        </div>


        <div class="col-lg-5">
            <div class="glass-card h-100">
                <h3 class="h5 mb-4 fw-bold text-white d-flex align-items-center gap-2">
                    <span class="text-info">🔐</span> Tài khoản DNSE
                </h3>

                @if (!string.IsNullOrEmpty(pref.DnseUsername))
                {
                    <div class="p-4 rounded mb-4" style="background: rgba(16, 185, 129, 0.05); border: 1px dashed rgba(16, 185, 129, 0.3);">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="bg-success rounded-circle" style="width: 12px; height: 12px;"></div>
                            <div class="fw-bold text-white">Đã kết nối thành công</div>
                        </div>
                        <div class="text-secondary small mb-1">Mã khách hàng:</div>
                        <div class="text-white font-monospace mb-4">@pref.DnseUsername</div>

                        <div class="d-flex gap-2">
                            <form asp-action="SyncDnse" method="post" class="flex-grow-1">
                                <button type="submit" class="btn btn-sm btn-info w-100 py-2">🔄 Đồng bộ ngay</button>
                            </form>
                            <form asp-action="UnlinkDnse" method="post" class="flex-grow-1" onsubmit="return confirm('Xác nhận hủy liên kết?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100 py-2">Hủy liên kết</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <form asp-action="SaveDnseAccount" method="post" class="d-flex flex-column gap-3">
                        <p class="text-secondary small">Nhập thông tin đăng nhập DNSE để đồng bộ danh mục thật.</p>
                        <div>
                            <label class="custom-label">SĐT / Mã KH DNSE</label>
                            <input type="text" name="DnseUsername" class="form-control custom-input" placeholder="Ví dụ: 1002419601" required />
                        </div>
                        <div>
                            <label class="custom-label">Mật khẩu DNSE</label>
                            <input type="password" name="DnsePassword" class="form-control custom-input" placeholder="Nhập mật khẩu" required />
                        </div>
                        <button type="submit" class="btn btn-outline-info w-100 py-2 mt-2">Kết nối tài khoản</button>
                    </form>
                }

                <div class="mt-4 p-3 rounded bg-white bg-opacity-5 border border-white border-opacity-10">
                    <div class="text-warning small d-flex gap-2">
                        <span>⚠️</span>
                        <span>Thông tin của bạn được dùng để đồng bộ danh mục và thiết lập mục tiêu giao dịch.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Target Configurations Table -->
    <div class="row g-4 mt-4">
        <div class="col-12">
            <div class="glass-card">
                <h3 class="h5 mb-4 fw-bold text-white d-flex align-items-center gap-2">
                    <span class="text-warning">📋</span> Danh sách cấu hình mục tiêu đầu tư
                </h3>
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle m-0" style="font-size: 0.85rem; border-color: rgba(255,255,255,0.05);">
                        <thead>
                            <tr class="text-secondary">
                                <th>Phân tiền mỗi lệnh</th>
                                <th>Mục tiêu lợi nhuận (Min cần đạt)</th>
                                <th>Ngày bắt đầu</th>
                                <th>Thời gian đầu tư</th>
                                <th>Khẩu vị rủi ro</th>
                                <th class="text-center" style="width: 280px;">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var preferencesList = ViewBag.PreferencesList as List<UserPreference> ?? new List<UserPreference>();
                            }
                            @foreach (var p in preferencesList)
                            {
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                    <td class="font-monospace text-white fw-bold">@p.AmountPerTrade.ToString("N0") đ</td>
                                    <td class="font-monospace text-warning fw-bold">@p.TargetAmount.ToString("N0") đ</td>
                                    <td>@(p.PlanStartDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td>@p.InvestmentHorizon</td>
                                    <td>
                                        @{
                                            var badgeColor = p.RiskTolerance switch
                                            {
                                                "Low" => "bg-success",
                                                "Medium" => "bg-warning text-dark",
                                                "High" => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                            var label = p.RiskTolerance switch
                                            {
                                                "Low" => "Thấp",
                                                "Medium" => "Trung bình",
                                                "High" => "Cao",
                                                _ => p.RiskTolerance
                                            };
                                        }
                                        <span class="badge @badgeColor">@label</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-2 justify-content-center">
                                            <form asp-action="RunPlanAnalysis" asp-controller="Copilot" method="post" class="m-0" onsubmit="showGlobalLoading()">
                                                <input type="hidden" name="prefId" value="@p.Id" />
                                                <button type="submit" class="btn btn-sm btn-primary px-3 py-1" style="font-size: 0.78rem; border-radius: 6px; background: linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%); border: none;">
                                                    🧠 Chạy phân tích AI
                                                </button>
                                            </form>
                                            <button type="button" onclick="deletePreference(@p.Id, this)" class="btn btn-sm btn-outline-danger px-3 py-1" style="font-size: 0.78rem; border-radius: 6px;">
                                                🗑️ Xóa
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Loading Overlay -->
<div id="globalLoadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(9, 10, 15, 0.85); z-index: 9999; justify-content: center; align-items: center; flex-direction: column;">
    <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem; color: #8b5cf6 !important;" role="status"></div>
    <div class="text-white fw-bold" style="font-size: 1.1rem; letter-spacing: 0.05em;">🧠 AI đang phân tích dữ liệu & lập kế hoạch tối ưu...</div>
    <div class="text-secondary small mt-2">Quá trình này có thể mất 10-15 giây, vui lòng không tắt trang.</div>
</div>

<script>
function showGlobalLoading() {
    document.getElementById('globalLoadingOverlay').style.display = 'flex';
}

function deletePreference(id, button) {
    if (!confirm("Bạn có chắc chắn muốn xóa cấu hình mục tiêu này không?")) {
        return;
    }
    
    fetch('/Copilot/DeletePreference?id=' + id, {
        method: 'POST'
    })
    .then(response => {
        if (!response.ok) {
            return response.json().then(data => { throw new Error(data.message || 'Không thể xóa cấu hình'); });
        }
        return response.json();
    })
    .then(data => {
        if (data.success) {
            const row = button.closest('tr');
            if (row) {
                row.remove();
            } else {
                location.reload();
            }
        } else {
            alert(data.message || 'Xóa thất bại.');
        }
    })
    .catch(error => {
        console.error(error);
        alert('Lỗi: ' + error.message);
    });
}
</script>

